
# Device identification
DEVICE_ID=edge-node-001

# Database (SQLite path relative to project root)
DATABASE_URL=sqlite+aiosqlite:///./healthguard.db

# Sensor configuration
MOCK_MODE=true
SENSOR_INTERVAL_SECONDS=5

# Central server sync
CENTRAL_SERVER_URL=https://central.healthguard.example.com/api
CENTRAL_API_KEY=your-api-key-here
SYNC_INTERVAL_SECONDS=300
SYNC_BATCH_SIZE=100



# Server
HOST=0.0.0.0
PORT=8000


